{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Tickets": "Host=localhost;Port=5432;Database=ticket_triage;Username=ticket_triage;Password=ticket_triage",
    "Triage": "Host=localhost;Port=5432;Database=ticket_triage;Username=ticket_triage;Password=ticket_triage",
    "Identity": "Host=localhost;Port=5432;Database=ticket_triage;Username=ticket_triage;Password=ticket_triage",
    "Notifications": "Host=localhost;Port=5432;Database=ticket_triage;Username=ticket_triage;Password=ticket_triage",
    "Reporting": "Host=localhost;Port=5432;Database=ticket_triage;Username=ticket_triage;Password=ticket_triage",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "ticket-triage",
    "Audience": "ticket-triage-clients",
    "SigningKey": "REPLACE_WITH_BASE64_32BYTE_SECRET_VIA_ENV_OR_SECRETS_MANAGER",
    "AccessTokenMinutes": 15
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "Otel": {
    "ServiceName": "TicketTriage.Host",
    "OtlpEndpoint": ""
  },
  "Notifications": {
    "Smtp": {
      "Host": "",
      "Port": 587,
      "EnableSsl": true,
      "Username": "",
      "Password": "",
      "FromAddress": "no-reply@ticket-triage.local"
    }
  },
  "Sqs": {
    "ServiceUrl": "http://localhost:4566",
    "Region": "us-east-1",
    "Queues": {
      "TicketsInbox": "http://localhost:4566/000000000000/tickets-inbox",
      "TriageInbox": "http://localhost:4566/000000000000/triage-inbox",
      "NotificationsInbox": "http://localhost:4566/000000000000/notifications-inbox",
      "ReportingInbox": "http://localhost:4566/000000000000/reporting-inbox"
    },
    "Routes": {
      "TicketCreated": [
        "http://localhost:4566/000000000000/triage-inbox",
        "http://localhost:4566/000000000000/reporting-inbox"
      ],
      "TicketTriaged": [
        "http://localhost:4566/000000000000/tickets-inbox",
        "http://localhost:4566/000000000000/notifications-inbox",
        "http://localhost:4566/000000000000/reporting-inbox"
      ],
      "TicketTriageFailed": [
        "http://localhost:4566/000000000000/tickets-inbox",
        "http://localhost:4566/000000000000/reporting-inbox"
      ],
      "TicketResolved": [
        "http://localhost:4566/000000000000/notifications-inbox",
        "http://localhost:4566/000000000000/reporting-inbox"
      ]
    }
  },
  "Triage": {
    "Concurrency": {
      "MaxConcurrentTriages": 4,
      "MaxQueuedTriages": 20
    },
    "Cache": {
      "TtlHours": 24
    },
    "Presidio": {
      "BaseUrl": "http://localhost:5002"
    },
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1",
      "TimeoutSeconds": 60
    },
    "OpenAi": {
      "BaseUrl": "https://api.openai.com",
      "ApiKey": "",
      "Model": "gpt-4o-mini",
      "TimeoutSeconds": 15
    },
    "Anthropic": {
      "BaseUrl": "https://api.anthropic.com",
      "ApiKey": "",
      "Model": "claude-3-5-sonnet-latest",
      "TimeoutSeconds": 15
    },
    "Gemini": {
      "BaseUrl": "https://generativelanguage.googleapis.com",
      "ApiKey": "",
      "Model": "gemini-1.5-flash",
      "TimeoutSeconds": 15
    }
  }
}
