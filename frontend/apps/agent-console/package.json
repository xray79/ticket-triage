{
  "name": "agent-console",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --karma-config karma.conf.js",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "e2e": "playwright test",
    "fetch:openapi": "node -e \"fetch('http://localhost:5000/swagger/v1/swagger.json').then(r=>r.json()).then(j=>require('fs').writeFileSync('openapi.json', JSON.stringify(j, null, 2) + '\\n'))\"",
    "generate:api-types": "openapi-typescript openapi.json -o src/app/core/api/generated/schema.d.ts",
    "sync:api-contract": "npm run fetch:openapi && npm run generate:api-types"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@sentry/angular": "^10.63.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular-eslint/builder": "^18.4.3",
    "@angular-eslint/eslint-plugin": "^18.4.3",
    "@angular-eslint/eslint-plugin-template": "^18.4.3",
    "@angular-eslint/template-parser": "^18.4.3",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^18.2.0",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "~5.5.2"
  }
}
