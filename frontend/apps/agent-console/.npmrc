# openapi-typescript@7.13.0 (a devDependency, not part of the shipped bundle) declares a peer
# range of typescript@^5.x and hasn't added TypeScript 6 support yet, conflicting with Angular
# 22's own typescript@~6.0.3 requirement. Verified npm run sync:api-contract still generates an
# identical schema.d.ts under TS 6 despite the stale peer declaration, so this is a real,
# understood gap in openapi-typescript's peer metadata, not a genuine incompatibility.
legacy-peer-deps=true
